<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://jcp.org"
         xmlns:xsi="http://w3.org"
         xsi:schemaLocation="http://jcp.org http://jcp.org/web-app_4_0.xsd"
         version="4.0">

    <display-name>Bancoweb1</display-name>

    <!-- Esto obliga al servidor a cargar tu clase CorsFilter -->
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>com.sena.bancoweb.filter.CorsFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
